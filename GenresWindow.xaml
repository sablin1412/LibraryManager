<Window x:Class="LibraryManager.GenresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление жанрами" Height="400" Width="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GenresDataGrid" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="GenresDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Margin="0,15,0,15">
            <TextBlock Text="Название жанра:" FontWeight="Bold"/>
            <TextBox x:Name="NameTextBox" Margin="0,5,0,10" Padding="2"/>
            
            <TextBlock Text="Описание:" FontWeight="Bold"/>
            <TextBox x:Name="DescriptionTextBox" Height="50" TextWrapping="Wrap" AcceptsReturn="True" Padding="2"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Добавить" Click="AddGenre_Click" Margin="0,0,10,0" Padding="15,5" Background="#E6F4EA"/>
            <Button Content="Сохранить изменения" Click="EditGenre_Click" Margin="0,0,10,0" Padding="15,5"/>
            <Button Content="Удалить" Click="DeleteGenre_Click" Padding="15,5" Background="#FCE8E6"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="LibraryManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление библиотекой" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="GenreFilterComboBox" Width="120" Margin="0,0,15,0" DisplayMemberPath="Name" SelectionChanged="Filter_SelectionChanged"/>

            <TextBlock Text="Автор:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="AuthorFilterComboBox" Width="120" Margin="0,0,15,0" DisplayMemberPath="LastName" SelectionChanged="Filter_SelectionChanged"/>

            <Button Content="Сбросить фильтры" Click="ResetFilters_Click" Margin="0,0,20,0" Padding="10,0"/>
            
            <TextBlock x:Name="BooksCountTextBlock" Text="Всего книг: 0" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <DataGrid x:Name="BooksDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author.LastName}" Width="*"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre.Name}" Width="*"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="80"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
            <Button Content="Авторы" Click="ManageAuthors_Click" Margin="0,0,10,0" Padding="15,5"/>
            <Button Content="Жанры" Click="ManageGenres_Click" Margin="0,0,15,0" Padding="15,5"/>
            
            <Button Content="Добавить" Click="AddBook_Click" Margin="0,0,10,0" Padding="15,5" Background="#E6F4EA"/>
            <Button Content="Редактировать" Click="EditBook_Click" Margin="0,0,10,0" Padding="15,5"/>
            <Button Content="Удалить" Click="DeleteBook_Click" Padding="15,5" Background="#FCE8E6"/>
        </StackPanel>
    </Grid>
</Window>